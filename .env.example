# ═══════════════════════════════════════════════════════════════
# Environment Variables — Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════════

# ── App ──
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/my_app

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Auth ──
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
MFA_ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-string

# ── OAuth: Google ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/oauth/google/callback

# ── Email (Resend) ──
RESEND_API_KEY=
EMAIL_FROM=noreply@myapp.com

# ── File Storage (GCS) ──
GCS_BUCKET=
GCS_PROJECT_ID=
GCS_KEY_FILE=

# ── Seazona API ──
SEAZONA_API_KEY=
SEAZONA_SECRET=
SEAZONA_BASE_URL=https://diamondapi.labzona.net/

# ── Authorize.net ──
AUTHORIZE_NET_API_LOGIN=
AUTHORIZE_NET_TRANSACTION_KEY=
AUTHORIZE_NET_ENV=sandbox

# ── Admin ──
ADMIN_NOTIFICATION_EMAIL=
