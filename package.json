{
  "name": "my-app",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @my-app/api db:generate",
    "db:migrate": "pnpm --filter @my-app/api db:migrate",
    "db:seed": "pnpm --filter @my-app/api db:seed",
    "clean": "turbo clean",
    "setup": "node scripts/setup.js"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  }
}
